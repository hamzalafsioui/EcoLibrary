    "components": {
        "schemas": {
            "Book": {
                "title": "Book",
                "description": "Book model",
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 1
                    },
                    "title": {
                        "type": "string",
                        "example": "Clean Architecture"
                    },
                    "author": {
                        "type": "string",
                        "example": "Robert C. Martin"
                    },
                    "year": {
                        "type": "integer",
                        "example": 2008
                    },
                    "category_id": {
                        "type": "integer",
                        "example": 2
                    },
                    "views_count": {
                        "type": "integer",
                        "example": 150
                    },
                    "is_available": {
                        "type": "boolean",
                        "example": true
                    },
                    "total_count": {
                        "type": "integer",
                        "example": 5
                    },
                    "degraded_count": {
                        "type": "integer",
                        "example": 1
                    },
                    "created_at": {
                        "type": "string",
                        "format": "date-time",
                        "example": "2023-01-01T00:00:00.000000Z"
                    },
                    "updated_at": {
                        "type": "string",
                        "format": "date-time",
                        "example": "2023-01-01T00:00:00.000000Z"
                    },
                    "category": {
                        "$ref": "#/components/schemas/Category"
                    }
                },
                "type": "object"
            },
            "Category": {
                "title": "Category",
                "description": "Category model",
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 1
                    },
                    "name": {
                        "type": "string",
                        "example": "IT"
                    },
                    "description": {
                        "type": "string",
                        "example": "IT books"
                    },
                    "books_count": {
                        "description": "Included when requested withCount",
                        "type": "integer",
                        "example": 10
                    },
                    "created_at": {
                        "type": "string",
                        "format": "date-time",
                        "example": "2023-01-01T00:00:00.000000Z"
                    },
                    "updated_at": {
                        "type": "string",
                        "format": "date-time",
                        "example": "2023-01-01T00:00:00.000000Z"
                    }
                },
                "type": "object"
            },
            "User": {
                "title": "User",
                "description": "User model",
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 1
                    },
                    "name": {
                        "type": "string",
                        "example": "Hamza Lafsioui"
                    },
                    "email": {
                        "type": "string",
                        "format": "email",
                        "example": "hamza@example.com"
                    },
                    "role": {
                        "type": "string",
                        "example": "reader"
                    },
                    "email_verified_at": {
                        "type": "string",
                        "format": "date-time",
                        "example": "2023-01-01T00:00:00.000000Z"
                    },
                    "created_at": {
                        "type": "string",
                        "format": "date-time",
                        "example": "2023-01-01T00:00:00.000000Z"
                    },
                    "updated_at": {
                        "type": "string",
                        "format": "date-time",
                        "example": "2023-01-01T00:00:00.000000Z"
                    },
                    "token": {
                        "description": "Access token returned on login/register",
                        "type": "string",
                        "example": "1|xxxxxxxxxxxxxxxxxxxxxxxxx"
                    }
                },
                "type": "object"
            }
        },
        "securitySchemes": {
            "sanctum": {
                "type": "apiKey",
                "description": "Enter token in format (Bearer <token>)",
                "name": "Authorization",
                "in": "header"
            }
        }
    },
    "tags": [
        {
            "name": "Auth",
            "description": "Auth"
        },
        {
